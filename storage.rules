rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Recibos de gastos: receipts/{companyId}/{expenseId}.jpg
    match /receipts/{companyId}/{fileName} {
      // Cualquier usuario autenticado de la empresa puede leer/escribir su recibo.
      // (La validación fina de propiedad vive en las reglas de Firestore.)
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
